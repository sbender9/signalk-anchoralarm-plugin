{
  "name": "signalk-anchoralarm-plugin",
  "version": "2.0.0-beta.2",
  "description": "Plugin that checks the vessel position to see if there's anchor drift",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "$NODE dist/index.js",
    "prettier": "prettier --write .",
    "lint": "eslint --fix",
    "ci-lint": "eslint && prettier --check .",
    "ci-test": "npm run build && npm run test && npm run ci-lint",
    "format": "npm run prettier && npm run lint"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "appIcon": "images/anchoralarm.png",
    "displayName": "Anchor Alarm"
  },
  "author": {
    "name": "Scott Bender",
    "email": "scott@scottbender.net"
  },
  "license": "ISC",
  "dependencies": {
    "@signalk/server-api": "^2.0.0",
    "@tsconfig/node20": "^20.1.9",
    "baconjs": "^0.7.88",
    "eslint-config-prettier": "^10.1.8",
    "geolib": "^3.3.3",
    "lodash": "^4.17.4",
    "typescript-eslint": "^8.58.1"
  },
  "devDependencies": {
    "@signalk/github-create-release": "^1.0.1",
    "@types/node": "^20.0.0",
    "eslint": "^9.33.0",
    "prettier": "^2.7.1",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist/**/*",
    "public/**/*",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sbender9/signalk-anchoralarm-plugin"
  }
}
